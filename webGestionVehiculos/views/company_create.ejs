<%- include("partials/header", { title: "Crear empresa - Nethive" }) %>

<section class="auth-card" style="max-width: 500px; margin: 0 auto;">
  <h2>Crear nueva empresa</h2>
  <p>Crea tu empresa y gestiona tu flota de vehículos.</p>
  
  <form action="/company/create" method="post" class="auth-form">
    <label>
      Nombre de la empresa
      <input type="text" name="companyName" required placeholder="Mi Empresa S.L." />
    </label>
    <label>
      Email de la empresa
      <input type="email" name="companyEmail" required placeholder="info@miempresa.com" />
    </label>
    <button type="submit" class="button button-primary">Crear empresa</button>
  </form>
</section>

<%- include("partials/footer") %>
