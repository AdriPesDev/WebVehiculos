<%- include('partials/header', { title: 'Panel superadministrador | Nethive' }) %>

<section class="dashboard">
  <% const normalizeStates = (vehicle) => vehicle.states || (vehicle.status ? [vehicle.status] : ['disponible']); %>
  <% const badgeClass = (states) =>
      (states.includes('mantenimiento') || states.includes('maintenance'))
        ? 'badge-danger'
        : (states.includes('en_uso') || states.includes('ocupado'))
        ? 'badge-warning'
        : 'badge-success';
  %>

  <div class="dashboard-header">
    <h2>Panel de superadministrador</h2>
    <p>Bienvenido, <strong><%= user.name %></strong></p>
  </div>

  <div class="admin-cards">
    <div class="admin-card admin-card-vehicles">
      <h3>🏢 Empresas</h3>
      <span class="stat-number"><%= companies.length %></span>
      <p>registradas</p>
    </div>
    <div class="admin-card admin-card-employees">
      <h3>👥 Usuarios</h3>
      <span class="stat-number"><%= users.length %></span>
      <p>totales</p>
    </div>
    <div class="admin-card admin-card-requests">
      <h3>🚗 Vehículos</h3>
      <span class="stat-number"><%= vehicles.length %></span>
      <p>en el sistema</p>
    </div>
    <div class="admin-card">
      <h3>🔧 En mantenimiento</h3>
      <span class="stat-number"><%= vehicles.filter((v) => normalizeStates(v).includes('mantenimiento') || normalizeStates(v).includes('maintenance')).length %></span>
      <p>vehículos</p>
    </div>
  </div>

  <div class="table-section">
    <h3>Empresas</h3>
    <table>
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Email</th>
          <th>Administrador</th>
          <th>Vehículos</th>
          <th>Registrada</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% companies.forEach((company) => {
             const admin = users.find((u) => u.id === company.admin_id);
             const companyVehicles = vehicles.filter((v) => v.company_id === company.id);
        %>
        <tr>
          <td><%= company.name %></td>
          <td><%= company.email %></td>
          <td><%= admin?.name || 'N/A' %></td>
          <td><%= companyVehicles.length %></td>
          <td><%= new Date(company.createdAt).toLocaleDateString('es-ES') %></td>
          <td>
            <form action="/superadmin/company/delete" method="post" style="display: inline;"
                  onsubmit="return confirm('¿Eliminar la empresa «<%= company.name %>» y todos sus datos? Esta acción no se puede deshacer.')">
              <input type="hidden" name="companyId" value="<%= company.id %>" />
              <button type="submit" class="button button-small button-danger">Eliminar</button>
            </form>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <div class="table-section">
    <h3>Usuarios</h3>
    <table>
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Email</th>
          <th>Rol</th>
          <th>Empresa</th>
          <th>Activo</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach((userItem) => {
             const company = companies.find((c) => c.id === userItem.company_id);
        %>
        <tr>
          <td><%= userItem.name %></td>
          <td><%= userItem.email %></td>
          <td><span class="badge"><%= userItem.role %></span></td>
          <td><%= company?.name || 'Sin empresa' %></td>
          <td><%= userItem.active ? 'Sí' : 'No' %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <div class="table-section">
    <h3>Vehículos del sistema</h3>
    <table>
      <thead>
        <tr>
          <th>Modelo</th>
          <th>Matrícula</th>
          <th>Empresa</th>
          <th>Estados</th>
          <th>Ubicación</th>
          <th>Último mantenimiento</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% vehicles.forEach((vehicle) => {
             const company = companies.find((c) => c.id === vehicle.company_id);
             const states = normalizeStates(vehicle);
        %>
        <tr>
          <td><%= vehicle.model %></td>
          <td><%= vehicle.plate %></td>
          <td><%= company?.name || 'N/A' %></td>
          <td>
            <span class="badge <%= badgeClass(states) %>"><%= states.join(', ') %></span>
          </td>
          <td><%= vehicle.location %></td>
          <td><%= vehicle.maintenanceEnd ? new Date(vehicle.maintenanceEnd).toLocaleDateString('es-ES') : 'N/A' %></td>
          <td>
            <a href="/vehicle/<%= vehicle.id %>" class="button button-small button-outline">Detalle</a>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</section>

<%- include('partials/footer') %>
