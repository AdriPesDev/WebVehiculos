<%- include('partials/header', { title: 'Panel de usuario | Nethive' }) %>

<section class="dashboard">
  <div class="dashboard-header">
    <h2>Bienvenido, <%= currentUser.name %></h2>
    <p>Usuario regular de Nethive. Consulta la flota disponible para tu siguiente reparto.</p>
  </div>

  <% if (availableVehicles.length) { %>
  <div class="vehicle-grid">
    <% availableVehicles.forEach((vehicle) => { %>
    <article class="vehicle-card">
      <h3><%= vehicle.model %></h3>
      <p>Matricula: <strong><%= vehicle.plate %></strong></p>
      <p>Capacidad: <strong><%= vehicle.capacity %></strong></p>
      <p>Ubicación: <strong><%= vehicle.location %></strong></p>
      <span class="badge badge-success">Disponible</span>
    </article>
    <% }); %>
  </div>
  <% } else { %>
  <div class="empty-state">
    <h3>No hay vehículos disponibles</h3>
    <p>La próxima disponibilidad es el <strong><%= nextAvailability %></strong>.</p>
  </div>
  <% } %>
</section>

<%- include('partials/footer') %>
