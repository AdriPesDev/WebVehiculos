<%- include("partials/header", { title: "Empresas disponibles - Nethive" }) %>

<section class="dashboard">
  <div class="dashboard-header">
    <h2>Empresas disponibles</h2>
    <p>Solicita acceso a una empresa para comenzar a trabajar.</p>
  </div>

  <% if (companies.length === 0) { %>
    <div class="empty-state">
      <h3>No hay empresas disponibles</h3>
      <p>Intenta crear la tuya propia.</p>
      <a href="/company/create" class="button button-primary">Crear empresa</a>
    </div>
  <% } else { %>
    <div class="company-grid">
      <% companies.forEach((company) => { %>
        <article class="company-card">
          <h3><%= company.name %></h3>
          <p><%= company.email %></p>
          <p><small>Registrada el <%= new Date(company.createdAt).toLocaleDateString("es-ES") %></small></p>
          <form action="/company/join/<%= company.id %>" method="post">
            <button type="submit" class="button button-primary">Solicitar acceso</button>
          </form>
        </article>
      <% }); %>
    </div>
  <% } %>
</section>

<%- include("partials/footer") %>
