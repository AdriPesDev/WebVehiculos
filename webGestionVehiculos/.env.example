# ─────────────────────────────────────────────────────────────────────────
# Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS (frontend origin)
CORS_ORIGIN=http://localhost:5173

# Session Secret (change this to a random string in production)
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# Initial User Passwords (only used when creating new users.json)
# If not provided, random passwords will be generated and printed to console
SUPERADMIN_PASSWORD=your-superadmin-password
ADMIN_PASSWORD=your-admin-password

# Database (if using a database in the future)
# DATABASE_URL=sqlite:./data/app.db
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=vehiculos_db
# DB_USER=admin
# DB_PASSWORD=your-password

# File Upload Configuration
# MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
# UPLOAD_DIR=./uploads

# Email Configuration (for future notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@nethive.com

# API Configuration
# API_BASE_URL=http://localhost:3000/api

# Logging
# LOG_LEVEL=info
# LOG_FILE=./logs/app.log
