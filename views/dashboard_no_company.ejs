<%- include("partials/header", { title: "Sin empresa - Nethive" }) %>

<section class="dashboard">
  <div class="dashboard-header">
    <h2>Bienvenido, <%= user.name %></h2>
    <p>No perteneces a ninguna empresa aún. Elige una opción:</p>
  </div>

  <div class="options-grid">
    <article class="option-card">
      <h3>Crear una nueva empresa</h3>
      <p>Sé el administrador de tu propia empresa de distribución.</p>
      <a href="/company/create" class="button button-primary">Crear empresa</a>
    </article>

    <article class="option-card">
      <h3>Unirte a una empresa existente</h3>
      <p>Solicita acceso a una empresa ya registrada en el sistema.</p>
      <a href="/company/list" class="button button-primary">Ver empresas</a>
    </article>
  </div>
</section>

<%- include("partials/footer") %>
