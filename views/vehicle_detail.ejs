<%- include('partials/header', { title: vehicle.model + ' — Detalle | Nethive' }) %>

<% const normalizeStates = (v) => v.states || (v.status ? [v.status] : ['disponible']); %>
<% const states = normalizeStates(vehicle); %>
<% const badgeClass = (states.includes('mantenimiento') || states.includes('maintenance'))
    ? 'badge-danger'
    : (states.includes('en_uso') || states.includes('ocupado'))
    ? 'badge-warning'
    : 'badge-success'; %>

<section class="dashboard">
  <div class="dashboard-header">
    <a href="/dashboard" class="button button-small button-outline" style="margin-bottom: 1rem; display: inline-flex;">← Volver al panel</a>
    <h2>🚗 <%= vehicle.model %></h2>
    <p>Matrícula: <strong><%= vehicle.plate %></strong> &nbsp;|&nbsp; Empresa: <strong><%= company?.name || 'N/A' %></strong></p>
  </div>

  <div class="admin-cards">
    <div class="admin-card admin-card-vehicles">
      <h3>📋 Estado actual</h3>
      <div style="margin-top: 0.5rem;">
        <span class="badge <%= badgeClass %>"><%= states.join(', ') %></span>
      </div>
    </div>
    <div class="admin-card admin-card-employees">
      <h3>📦 Capacidad</h3>
      <span class="stat-number" style="font-size: 1.8rem;"><%= vehicle.capacity %></span>
    </div>
    <div class="admin-card admin-card-requests">
      <h3>📍 Ubicación</h3>
      <span class="stat-number" style="font-size: 1.5rem;"><%= vehicle.location %></span>
    </div>
    <div class="admin-card">
      <h3>🗓️ Total viajes</h3>
      <span class="stat-number"><%= vehicleTrips.length %></span>
    </div>
  </div>

  <!-- Historial de viajes -->
  <div class="table-section">
    <h3>Historial de viajes</h3>
    <% if (vehicleTrips.length === 0) { %>
      <p style="color: var(--muted);">Este vehículo aún no tiene viajes registrados.</p>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Conductor</th>
            <th>Salida</th>
            <th>Entrada</th>
            <th>Duración</th>
            <th>Pasajeros</th>
            <th>Estado</th>
          </tr>
        </thead>
        <tbody>
          <% vehicleTrips.forEach((trip) => {
            const driver = users.find((u) => u.id === trip.driver_id);
            const start = new Date(trip.checkoutTime);
            const end = trip.checkinTime ? new Date(trip.checkinTime) : null;
            const mins = end ? Math.round((end - start) / 60000) : null;
            const hours = mins !== null ? Math.floor(mins / 60) : null;
            const rem = mins !== null ? mins % 60 : null;
            const duration = mins === null ? '—' : hours > 0 ? `${hours}h ${rem}min` : `${mins}min`;
          %>
          <tr>
            <td><%= driver?.name || 'Desconocido' %></td>
            <td><%= start.toLocaleDateString('es-ES') %> <%= start.toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' }) %></td>
            <td><%= end ? (end.toLocaleDateString('es-ES') + ' ' + end.toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' })) : '—' %></td>
            <td><%= duration %></td>
            <td><%= trip.passengers?.length || 0 %></td>
            <td>
              <span class="badge <%= trip.status === 'active' ? 'badge-warning' : 'badge-success' %>">
                <%= trip.status === 'active' ? 'Activo' : 'Completado' %>
              </span>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>

  <!-- Historial de mantenimientos -->
  <div class="table-section">
    <h3>Historial de mantenimientos</h3>
    <% const history = vehicle.maintenanceHistory || []; %>
    <% if (history.length === 0) { %>
      <p style="color: var(--muted);">Este vehículo no tiene registros de mantenimiento.</p>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Inicio</th>
            <th>Fin</th>
            <th>Duración</th>
            <th>Estado</th>
          </tr>
        </thead>
        <tbody>
          <% [...history].reverse().forEach((entry, idx) => {
            const mStart = new Date(entry.start);
            const mEnd = entry.end ? new Date(entry.end) : null;
            const mMins = mEnd ? Math.round((mEnd - mStart) / 60000) : null;
            const mHours = mMins !== null ? Math.floor(mMins / 60) : null;
            const mRem = mMins !== null ? mMins % 60 : null;
            const mDuration = mMins === null ? 'En curso' : mHours > 0 ? `${mHours}h ${mRem}min` : `${mMins}min`;
          %>
          <tr>
            <td><%= history.length - idx %></td>
            <td><%= mStart.toLocaleDateString('es-ES') %> <%= mStart.toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' }) %></td>
            <td><%= mEnd ? (mEnd.toLocaleDateString('es-ES') + ' ' + mEnd.toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' })) : '—' %></td>
            <td><%= mDuration %></td>
            <td>
              <span class="badge <%= entry.end ? 'badge-success' : 'badge-danger' %>">
                <%= entry.end ? 'Completado' : 'En curso' %>
              </span>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
